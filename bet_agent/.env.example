# Perfil de ambiente: local | prd
APP_ENV=local

# Chaves principais
API_FOOTBALL_KEY=
# Opcional: chaves extras (CSV), usadas somente quando a principal bater limite diario.
API_FOOTBALL_FALLBACK_KEYS=
THE_ODDS_API_KEY=
API_FOOTBALL_AUTH_MODE=apisports

# Modo de dados
USE_SAMPLE_DATA=false
DATA_DIR=
PERSISTIR_EM_BANCO=true
NOME_ARQUIVO_BANCO=historico_apostas.db
# Opcional: caminho absoluto do diretorio do banco.
# Se vazio, usa DATA_DIR quando definido.
# Ex.: C:\Users\SeuUsuario\AppData\Local\OddsEdge\dados
# DIRETORIO_BANCO=

# Rede
REQUESTS_TRUST_ENV=false
SERVER_HOST=0.0.0.0
# Em cloud, normalmente nao precisa definir SERVER_PORT.
# O app tambem aceita a variavel PORT do provedor.
SERVER_PORT=8000

# Auto desligamento (local=true, prd=false)
ENABLE_IDLE_SHUTDOWN=true
IDLE_SHUTDOWN_SECONDS=25

# Controle de consumo da The Odds API
ODDS_ONLY_ACTIVE_SPORTS=true
ODDS_MAX_SPORTS_PER_RUN=2
ODDS_SPORTS=soccer_italy_serie_a,soccer_spain_la_liga,soccer_epl,soccer_brazil_campeonato

# Regras de recomendacao
MIN_PROBABILITY=0.65
MIN_EV=0.0
