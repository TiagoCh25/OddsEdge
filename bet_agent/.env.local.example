APP_ENV=local

# Chaves
API_FOOTBALL_KEY=
# Opcional: chaves extras (CSV), usadas somente quando a principal bater limite diario.
API_FOOTBALL_FALLBACK_KEYS=
THE_ODDS_API_KEY= 
API_FOOTBALL_AUTH_MODE=apisports

# Local
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENABLE_IDLE_SHUTDOWN=true
IDLE_SHUTDOWN_SECONDS=25
DATA_DIR=

# Rede
REQUESTS_TRUST_ENV=false
USE_SAMPLE_DATA=false
PERSISTIR_EM_BANCO=true
NOME_ARQUIVO_BANCO=historico_apostas.db
# DIRETORIO_BANCO=C:\Users\SeuUsuario\AppData\Local\Temp\OddsEdge\dados

# Economia de creditos
ODDS_ONLY_ACTIVE_SPORTS=true
ODDS_MAX_SPORTS_PER_RUN=2
ODDS_SPORTS=soccer_italy_serie_a,soccer_spain_la_liga,soccer_epl,soccer_brazil_campeonato

# Regras
# MIN_PROBABILITY=0.65
# MIN_EV=0.0
MIN_PROBABILITY=0.55
MIN_EV=0.01
